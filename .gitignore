# -------------------------
# Unreal Engine 5 .gitignore
# -------------------------

# Ignore build outputs and binaries
Binaries/
DerivedDataCache/
Intermediate/
Saved/
*.log

# Ignore user-specific project files
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcodeproj
*.xcworkspace
.vscode/
.idea/
*.vs/

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore temp files
*.tmp
*.temp
*.bak
*.backup

# Ignore auto-generated plugin files
Plugins/*/Binaries/
Plugins/*/Intermediate/
Plugins/*/Saved/

# Ignore project-specific IDE files
*.sln
*.suo
*.user
*.userprefs
*.ncb

# Ignore CrashReporter / Mac-specific crash logs
Saved/Crashes/

# Ignore auto-generated config caches
Config/DefaultEditorPerProjectUserSettings.ini
Config/DefaultEditorUserSettings.ini
Config/EditorPerProjectUserSettings.ini